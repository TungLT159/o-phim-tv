{
  "identifier": "default",
  "description": "Default capabilities for O Phim",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "store:default",
    "shell:default",
    "shell:allow-open",
    "shell:allow-execute",
    "fs:default",
    "fs:allow-read",
    "fs:allow-write",
    "dialog:default",
    "dialog:allow-save",
    "dialog:allow-open",
    "updater:default",
    "updater:allow-check",
    "updater:allow-download",
    "updater:allow-install"
  ]
}
